# Anthropic API key (required for real LLM mode)
ANTHROPIC_API_KEY=

# Optional: override default model (defaults to claude-haiku-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: force mock LLM mode regardless of API key presence
# Useful for demos / failure-mode walkthroughs without burning tokens
# FORCE_MOCK=1
